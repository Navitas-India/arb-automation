{
  "name": "arb-automation",
  "version": "1.0.0",
  "description": "Playwright test automation for ARBenefits Member Portal",
  "scripts": {
    "generate":        "ts-node agent/generate.ts",
    "generate:one":    "ts-node agent/generate.ts",
    "test":            "playwright test",
    "test:ui":         "playwright test --project=ui",
    "test:api":        "playwright test --project=api",
    "test:headed":     "playwright test --project=ui --headed",
    "test:debug":      "playwright test --debug",
    "report":          "playwright show-report",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open":     "allure open allure-report",
    "allure:report":   "npm run allure:generate && npm run allure:open"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "dotenv":            "^16.4.5"
  },
  "devDependencies": {
    "@playwright/test":  "^1.49.0",
    "allure-playwright": "^3.0.0",
    "ts-node":           "^10.9.2",
    "typescript":        "^5.4.5"
  }
}
